---
const people = [
  {
    name: 'A. Miller',
    avail: [160, 140, 160],
    projects: [
      { project: 'Alpha', color: 'bg-primary', hours: [80, 60, 40] },
      { project: 'Beta', color: 'bg-secondary', hours: [40, 40, 80] },
      { project: 'Internal', color: 'bg-amber-400', hours: [20, 20, 20] },
    ],
  },
  {
    name: 'B. Chen',
    avail: [160, 120, 160],
    projects: [
      { project: 'Alpha', color: 'bg-primary', hours: [120, 80, 80] },
      { project: 'Internal', color: 'bg-amber-400', hours: [20, 40, 60] },
    ],
  },
  {
    name: 'C. Smith',
    avail: [120, 160, 160],
    projects: [
      { project: 'Beta', color: 'bg-secondary', hours: [60, 80, 100] },
      { project: 'Internal', color: 'bg-amber-400', hours: [40, 20, 0] },
    ],
  },
  {
    name: 'D. Park',
    avail: [160, 160, 120],
    projects: [
      { project: 'Alpha', color: 'bg-primary', hours: [40, 80, 60] },
      { project: 'Beta', color: 'bg-secondary', hours: [80, 40, 20] },
    ],
  },
];

const projectList = [
  { name: 'Alpha', textColor: 'text-primary', bgColor: 'bg-primary' },
  { name: 'Beta', textColor: 'text-secondary', bgColor: 'bg-secondary' },
  { name: 'Internal', textColor: 'text-amber-500', bgColor: 'bg-amber-400' },
];

// Calculate project totals across all people and months
const projectTotals: Record<string, number> = {};
for (const p of projectList) projectTotals[p.name] = 0;
for (const person of people) {
  for (const proj of person.projects) {
    projectTotals[proj.project] += proj.hours.reduce((a: number, b: number) => a + b, 0);
  }
}

// Per-person monthly totals
const personMonthTotals = people.map(person =>
  [0, 1, 2].map(mi => person.projects.reduce((sum, pr) => sum + pr.hours[mi], 0))
);
---

<section class="relative pt-28 pb-20 md:pt-36 md:pb-28 overflow-hidden">
  <!-- Subtle background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-primary-50/60 to-white pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Left: Copy -->
      <div class="max-w-xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-light text-primary text-xs font-semibold mb-6 border border-primary/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Project Resource Planning, Optimized
        </div>

        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-heading leading-tight tracking-tight">
          <span class="text-heading">Re<span class="text-primary">Solve</span></span> your
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">
            project resource planning
          </span>
          chaos and 
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">
            maximize 
          </span>
          your objective
        </h1>

        <p class="mt-6 text-lg text-muted leading-relaxed">
          ReSolve helps assign monthly people hours per person and project, while respecting customizable constraints (availability, project demands, ...), to maximize total billable hours.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            data-track="hero-get-access"
            class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg bg-primary text-white font-semibold hover:bg-primary-hover transition-all shadow-lg shadow-primary/20 hover:shadow-xl hover:shadow-primary/30"
          >
            Get Access
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="#how-it-works"
            data-track="hero-how-it-works"
            class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg border border-border text-heading font-semibold hover:bg-surface transition-colors"
          >
            See How It Works
          </a>
        </div>
      </div>

      <!-- Right: Visual -->
      <div class="relative hidden md:block">
        <div class="relative w-full aspect-square max-w-md mx-auto">
          <!-- Background glow -->
          <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-primary/10 to-secondary/10 blur-2xl"></div>

          <!-- Main card -->
          <div class="relative bg-white rounded-2xl border border-border shadow-xl p-5 space-y-3">
            <!-- Header -->
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-primary"></div>
                <span class="text-xs font-semibold text-heading">Team Schedule | Q2 2026</span>
              </div>
              <span class="text-xs font-mono text-primary bg-primary-50 px-2 py-0.5 rounded">Optimized ✓</span>
            </div>

            <!-- Month/Person/Project grid -->
            <div class="space-y-3">
              <div class="overflow-hidden rounded-lg border border-border">
                <!-- Column headers -->
                <div class="grid grid-cols-[68px_1fr_1fr_1fr] bg-surface text-center">
                  <div class="px-2 py-1.5 text-[10px] font-semibold text-muted border-r border-border"></div>
                  <div class="px-2 py-1.5 text-[10px] font-semibold text-heading border-r border-border">Apr</div>
                  <div class="px-2 py-1.5 text-[10px] font-semibold text-heading border-r border-border">May</div>
                  <div class="px-2 py-1.5 text-[10px] font-semibold text-heading">Jun</div>
                </div>

                {/* Person rows */}
                {people.map((person, pi) => (
                  <div class={`border-t border-border ${pi % 2 === 1 ? 'bg-surface/50' : ''}`}>
                    {/* Project sub-rows */}
                    {person.projects.map((proj, ri) => (
                      <div class="grid grid-cols-[68px_1fr_1fr_1fr]">
                        <div class={`px-2 py-0.5 text-[10px] text-muted border-r border-border flex items-center ${ri === 0 ? 'font-semibold' : ''}`}>
                          {ri === 0 ? person.name : ''}
                        </div>
                        {proj.hours.map((h) => (
                          <div class="px-1 py-0.5 text-center border-r border-border last:border-r-0">
                            <div class="relative">
                              <div
                                class={`${proj.color} opacity-15 absolute inset-0 rounded-sm`}
                                style={`width: ${Math.round((h / 160) * 100)}%`}
                              ></div>
                              <span class={`relative text-[10px] font-medium ${h > 0 ? 'text-heading' : 'text-muted/40'}`}>
                                {h > 0 ? `${h}h` : '—'}
                              </span>
                            </div>
                          </div>
                        ))}
                      </div>
                    ))}
                    {/* Summary row: total / availability */}
                    <div class="grid grid-cols-[68px_1fr_1fr_1fr] border-t border-border/50 bg-surface/30">
                      <div class="px-2 py-0.5 text-[9px] text-muted border-r border-border flex items-center italic">avail.</div>
                      {[0, 1, 2].map((mi) => (
                        <div class="px-1 py-0.5 text-center border-r border-border last:border-r-0">
                          <span class={`text-[9px] font-semibold ${personMonthTotals[pi][mi] <= person.avail[mi] ? 'text-primary' : 'text-red-500'}`}>
                            {personMonthTotals[pi][mi]}
                          </span>
                          <span class="text-[9px] text-muted">/{person.avail[mi]}h</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>

              <!-- Project totals -->
              <div class="flex items-center justify-between gap-2">
                {projectList.map((p) => (
                  <div class="flex items-center gap-1.5">
                    <div class={`w-2 h-2 rounded-sm ${p.bgColor} opacity-80`}></div>
                    <span class="text-[10px] text-muted">{p.name}</span>
                    <span class={`text-[10px] font-bold ${p.textColor}`}>{projectTotals[p.name]}h</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Stats bar -->
            <div class="grid grid-cols-3 gap-2 pt-1">
              <div class="text-center p-2 rounded-lg bg-primary-50">
                <div class="text-base font-bold text-primary">94%</div>
                <div class="text-[10px] text-muted">Utilization</div>
              </div>
              <div class="text-center p-2 rounded-lg bg-secondary-light">
                <div class="text-base font-bold text-secondary">1320h</div>
                <div class="text-[10px] text-muted">Billable</div>
              </div>
              <div class="text-center p-2 rounded-lg bg-surface">
                <div class="text-base font-bold text-heading">4</div>
                <div class="text-[10px] text-muted">Team Members</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;

const personas = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: t(lang, 'whoPersona1Title'),
    desc: t(lang, 'whoPersona1Desc'),
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M17 18h1"/><path d="M12 18h1"/><path d="M7 18h1"/></svg>`,
    title: t(lang, 'whoPersona2Title'),
    desc: t(lang, 'whoPersona2Desc'),
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m4.9 4.9 14.2 14.2"/></svg>`,
    title: t(lang, 'whoPersona3Title'),
    desc: t(lang, 'whoPersona3Desc'),
  },
];

const checkmarks = [
  t(lang, 'whoCheck1'),
  t(lang, 'whoCheck2'),
  t(lang, 'whoCheck3'),
  t(lang, 'whoCheck4'),
  t(lang, 'whoCheck5'),
  t(lang, 'whoCheck6'),
];
---

<section id="who-its-for" class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="inline-block text-xs font-semibold text-primary uppercase tracking-wider mb-3">{t(lang, 'whoSectionLabel')}</span>
      <h2 class="text-3xl md:text-4xl font-bold text-heading">
        {t(lang, 'whoTitle')} <span class="text-primary">{t(lang, 'whoTitleHighlight')}</span>
      </h2>
      <p class="mt-4 text-muted max-w-2xl mx-auto">
        {t(lang, 'whoSubtitle')}
      </p>
    </div>

    <!-- Persona cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-14">
      {personas.map((p) => (
        <div class="bg-white rounded-xl border border-border p-6 hover:shadow-lg hover:border-primary/30 transition-all duration-300">
          <div class="w-12 h-12 rounded-lg bg-primary-light flex items-center justify-center text-primary mb-4">
            <Fragment set:html={p.icon} />
          </div>
          <h3 class="text-lg font-bold text-heading mb-2">{p.title}</h3>
          <p class="text-sm text-muted leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>

    <!-- Checklist -->
    <div class="bg-surface rounded-2xl border border-border p-8 md:p-10">
      <h3 class="text-lg font-bold text-heading mb-6 text-center">{t(lang, 'whoChecklistTitle')}</h3>
      <div class="grid sm:grid-cols-2 gap-x-8 gap-y-3 max-w-3xl mx-auto">
        {checkmarks.map((item) => (
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span class="text-sm text-heading">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

---
import type { Locale } from '../i18n/translations';
import { t, getAlternateLocale, getLocalePath } from '../i18n/translations';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const altLang = getAlternateLocale(lang);
const prefix = lang === 'de' ? '/de' : '';

const links = [
  { label: t(lang, 'navWhoItsFor'), href: `${prefix}/#who-its-for` },
  { label: t(lang, 'navHowItWorks'), href: `${prefix}/#how-it-works` },
  { label: t(lang, 'navFeatures'), href: `${prefix}/#features` },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-lg border-b border-border">
  <div class="max-w-6xl mx-auto flex items-center justify-between px-6 h-16">
    <!-- Logo -->
    <a href={`${prefix}/`} class="flex items-center group">
      <img src="/logo.png" alt="ReSolve" class="h-10 w-auto" />
    </a>

    <!-- Desktop Links -->
    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-muted hover:text-heading transition-colors"
        >
          {link.label}
        </a>
      ))}

      <!-- Language toggle -->
      <a
        href={getLocalePath(altLang, Astro.url.pathname)}
        class="text-xs font-semibold text-muted hover:text-heading transition-colors uppercase border border-border rounded px-2 py-1"
        aria-label={altLang === 'de' ? 'Auf Deutsch wechseln' : 'Switch to English'}
      >
        {altLang.toUpperCase()}
      </a>

      <a
        href={`${prefix}/contact`}
        data-track="nav-get-access"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-primary text-white font-semibold text-sm hover:bg-primary-hover transition-colors shadow-sm"
      >
        {t(lang, 'navGetInTouch')}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-muted hover:text-heading transition-colors"
      aria-label="Toggle menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-border bg-white">
    <div class="px-6 py-4 space-y-3">
      {links.map((link) => (
        <a
          href={link.href}
          class="block text-sm font-medium text-muted hover:text-heading transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href={`${prefix}/contact`}
        data-track="nav-get-access-mobile"
        class="block text-center px-5 py-2.5 rounded-lg bg-primary text-white font-semibold text-sm hover:bg-primary-hover transition-colors"
      >
        {t(lang, 'navGetInTouch')}
      </a>
      <a
        href={getLocalePath(altLang, Astro.url.pathname)}
        class="block text-center text-xs font-semibold text-muted hover:text-heading transition-colors uppercase border border-border rounded px-2 py-2"
      >
        {altLang === 'de' ? 'Deutsch' : 'English'}
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  // Close menu when a link is clicked
  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>

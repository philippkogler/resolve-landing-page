---
const painPoints = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 12l-2 2 2 2"/><path d="M14 12l2 2-2 2"/></svg>`,
    title: 'Spreadsheet Chaos',
    desc: 'Hours wasted juggling spreadsheets, manually shuffling people between projects every month.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`,
    title: 'Guesswork Decisions',
    desc: 'No way to know if a new project is feasible — or what accepting it costs the rest of the team.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    title: 'Lost Revenue',
    desc: 'Sub-optimal assignments leave billable hours on the table. Small improvements compound into big revenue.',
  },
];

const solutions = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
    title: 'Automated Optimization',
    desc: 'Our solver assigns hours optimally in seconds — considering every constraint you define.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    title: 'Instant Clarity',
    desc: 'See exactly how resources are allocated, who has capacity, and where bottlenecks appear.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/></svg>`,
    title: 'Maximize Revenue',
    desc: 'Every hour is accounted for. The optimizer finds the plan that maximizes your total billable hours.',
  },
];
---

<section id="problem" class="py-20 md:py-28 bg-surface">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="inline-block text-xs font-semibold text-primary uppercase tracking-wider mb-3">The Problem & Solution</span>
      <h2 class="text-3xl md:text-4xl font-bold text-heading">
        From planning chaos to <span class="text-primary">optimized clarity</span>
      </h2>
      <p class="mt-4 text-muted max-w-2xl mx-auto">
        Team leaders spend countless hours on resource planning. ReSolve replaces guesswork with mathematical optimization.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 md:gap-12">
      <!-- Pain side -->
      <div>
        <div class="flex items-center gap-2 mb-6">
          <div class="w-8 h-8 rounded-lg bg-rose-100 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-rose-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </div>
          <h3 class="text-sm font-bold uppercase tracking-wider text-rose-500">Without ReSolve</h3>
        </div>
        <div class="space-y-4">
          {painPoints.map((item) => (
            <div class="flex gap-4 p-4 rounded-xl bg-white border border-border hover:border-rose-200 transition-colors">
              <div class="shrink-0 w-10 h-10 rounded-lg bg-rose-50 text-rose-500 flex items-center justify-center">
                <Fragment set:html={item.icon} />
              </div>
              <div>
                <h4 class="font-semibold text-heading text-sm">{item.title}</h4>
                <p class="text-sm text-muted mt-1">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Solution side -->
      <div>
        <div class="flex items-center gap-2 mb-6">
          <div class="w-8 h-8 rounded-lg bg-primary-50 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h3 class="text-sm font-bold uppercase tracking-wider text-primary">With ReSolve</h3>
        </div>
        <div class="space-y-4">
          {solutions.map((item) => (
            <div class="flex gap-4 p-4 rounded-xl bg-white border border-border hover:border-primary/30 transition-colors">
              <div class="shrink-0 w-10 h-10 rounded-lg bg-primary-50 text-primary flex items-center justify-center">
                <Fragment set:html={item.icon} />
              </div>
              <div>
                <h4 class="font-semibold text-heading text-sm">{item.title}</h4>
                <p class="text-sm text-muted mt-1">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

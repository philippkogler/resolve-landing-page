---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { t } from '../i18n/translations';

const lang = 'en';
---

<Layout title={t(lang, 'impressumTitle')} description={t(lang, 'impressumDescription')} lang={lang}>
  <Navbar lang={lang} />

  <main class="pt-28 pb-20 md:pt-36 md:pb-28">
    <div class="max-w-3xl mx-auto px-6">
      <h1 class="text-3xl font-bold text-heading mb-4">{t(lang, 'impressumHeading')}</h1>

      <p class="text-body">
        {t(lang, 'impressumContactText')}
        <a href="mailto:philipp@re-solve.at" class="text-primary hover:underline">philipp@re-solve.at</a>
      </p>

      <p class="mt-4 text-body">{t(lang, 'impressumResponsibleText')}</p>

      <img
        src="/imprint.png"
        alt="Impressum"
        width="300"
        class="mt-4"
      />

      <div class="mt-12 text-center">
        <a href="/" class="inline-flex items-center gap-2 text-primary hover:text-primary-hover font-medium transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          {t(lang, 'backToLandingPage')}
        </a>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

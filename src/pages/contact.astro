---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const useCaseOptions = [
  'Option 1',
  'Option 2',
  'Option 3',
  'Option 4',
  'Option 5',
];
---

<Layout title="Get Access — ReSolve" description="Request early access to ReSolve and start optimizing your team's resource planning.">
  <Navbar />

  <section class="pt-28 pb-20 md:pt-36 md:pb-28 min-h-screen">
    <div class="max-w-2xl mx-auto px-6">
      <!-- Header -->
      <div class="text-center mb-10">
        <a href="/" class="inline-flex items-center gap-1 text-sm text-muted hover:text-primary transition-colors mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Back to home
        </a>
        <h1 class="text-3xl md:text-4xl font-bold text-heading">Get Access</h1>
        <p class="mt-3 text-muted">
          Tell us about yourself and how you'd use ReSolve. We'll be in touch shortly.
        </p>
      </div>

      <!-- Form -->
      <form id="contact-form" class="bg-white rounded-2xl border border-border shadow-sm p-6 md:p-8 space-y-6">
        <!-- Name -->
        <div>
          <label for="name" class="block text-sm font-semibold text-heading mb-1.5">Name <span class="text-rose-500">*</span></label>
          <input
            type="text"
            id="name"
            name="role"
            required
            placeholder="Your full name"
            class="w-full rounded-lg border border-border bg-surface px-4 py-2.5 text-sm text-heading placeholder:text-muted/60 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
          />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-sm font-semibold text-heading mb-1.5">Email <span class="text-rose-500">*</span></label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="you@company.com"
            class="w-full rounded-lg border border-border bg-surface px-4 py-2.5 text-sm text-heading placeholder:text-muted/60 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
          />
        </div>

        <!-- Affiliation -->
        <div>
          <label for="affiliation" class="block text-sm font-semibold text-heading mb-1.5">Company / Affiliation</label>
          <input
            type="text"
            id="affiliation"
            name="company"
            placeholder="Your company or organization"
            class="w-full rounded-lg border border-border bg-surface px-4 py-2.5 text-sm text-heading placeholder:text-muted/60 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
          />
        </div>

        <!-- Use Case (Multi-select checkboxes) -->
        <fieldset>
          <legend class="block text-sm font-semibold text-heading mb-3">Use Case</legend>
          <div class="grid sm:grid-cols-2 gap-2">
            {useCaseOptions.map((option) => (
              <label class="flex items-center gap-2.5 p-3 rounded-lg border border-border hover:border-primary/30 cursor-pointer transition-colors has-[:checked]:bg-primary-50 has-[:checked]:border-primary/30">
                <input
                  type="checkbox"
                  name="useCase"
                  value={option}
                  class="w-4 h-4 rounded border-border text-primary focus:ring-primary/30 accent-primary"
                />
                <span class="text-sm text-body">{option}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <!-- Message -->
        <div>
          <label for="message" class="block text-sm font-semibold text-heading mb-1.5">Message</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            placeholder="Tell us about your team, your planning challenges, or anything else..."
            class="w-full rounded-lg border border-border bg-surface px-4 py-2.5 text-sm text-heading placeholder:text-muted/60 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-y"
          ></textarea>
        </div>

        <!-- Submit -->
        <button
          type="submit"
          class="w-full inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-primary text-white font-semibold hover:bg-primary-hover transition-colors shadow-sm disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span id="btn-text">Submit Request</span>
          <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </button>
      </form>

      <!-- Success message -->
      <div id="success-message" class="hidden mt-6 p-6 rounded-2xl bg-primary-50 border border-primary/20 text-center">
        <div class="w-12 h-12 rounded-full bg-primary/10 text-primary flex items-center justify-center mx-auto mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h3 class="text-lg font-bold text-heading">Thank you!</h3>
        <p class="text-sm text-muted mt-1">We've received your request and will be in touch soon.</p>
      </div>

      <!-- Error message -->
      <div id="error-message" class="hidden mt-6 p-6 rounded-2xl bg-rose-50 border border-rose-200 text-center">
        <h3 class="text-lg font-bold text-heading">Something went wrong</h3>
        <p class="text-sm text-muted mt-1">Please try again or reach out to us directly.</p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  import { submitForm } from '../lib/analytics';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btnText = document.getElementById('btn-text')!;
  const btnSpinner = document.getElementById('btn-spinner')!;
  const successMsg = document.getElementById('success-message')!;
  const errorMsg = document.getElementById('error-message')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Reset messages
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    // Show loading
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    btnText.textContent = 'Submitting...';
    btnSpinner.classList.remove('hidden');

    const formData = new FormData(form);

    try {
      const res = await submitForm({
        email: (formData.get('email') as string) ?? '',
        company: (formData.get('company') as string) ?? '',
        role: (formData.get('role') as string) ?? '',
        usecase: formData.getAll('useCase').join(', '),
      });

      if (res.ok) {
        form.classList.add('hidden');
        successMsg.classList.remove('hidden');
      } else {
        throw new Error('Request failed');
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      btnText.textContent = 'Submit Request';
      btnSpinner.classList.add('hidden');
    }
  });
</script>
